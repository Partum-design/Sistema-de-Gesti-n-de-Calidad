# Base de datos
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/indusecc-os

# JWT
JWT_SECRET=tu_secreto_muy_largo_y_aleatorio_aqui
JWT_EXPIRE=1h
JWT_REFRESH_SECRET=otro_secreto_largo_aleatorio
